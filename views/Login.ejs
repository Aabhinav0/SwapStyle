<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Login | SwapStyle', stylesheet: '/login.css' }) %>
<body>
    <% const viewError = typeof error !== 'undefined' ? error : null; %>
    <% const viewSuccessMessage = typeof successMessage !== 'undefined' ? successMessage : null; %>
    <%- include('partials/navbar', { activePage: 'login' }) %>


    <main class="page-shell auth-shell">
        <section class="container">
            <div class="hero-panel auth-layout">
                <div class="auth-copy">
                    <span class="eyebrow">Welcome back</span>
                    <h1>Sign in to manage listings, swaps, and saved pieces.</h1>
                    <p class="lead">The updated experience is quieter, clearer, and built to keep the focus on good items and trusted exchanges.</p>
                    <div class="panel-list auth-benefits">
                        <div class="list-row">
                            <strong>Track your wardrobe</strong>
                            <span class="muted">Dashboard and inventory visibility</span>
                        </div>
                        <div class="list-row">
                            <strong>Swap with confidence</strong>
                            <span class="muted">Condition, points, and listing details front and center</span>
                        </div>
                        <div class="list-row">
                            <strong>Return anytime</strong>
                            <span class="muted">A calmer interface that feels easier to trust</span>
                        </div>
                    </div>
                    <div class="auth-side-actions">
                        <a href="/itemlisting" class="btn btn-secondary">Browse marketplace</a>
                        <a href="/Signin" class="btn btn-outline">Create an account</a>
                    </div>
                </div>

                <div class="auth-panel">
                    <div class="auth-header">
                        <span class="eyebrow">Member access</span>
                        <h2>Login</h2>
                        <p class="muted">Use the same account you created during sign up.</p>
                    </div>

                    <% if (viewError) { %>
                        <div class="message error"><%= viewError %></div>
                    <% } %>

                    <% if (viewSuccessMessage) { %>
                        <div class="message success"><%= viewSuccessMessage %></div>
                    <% } %>

                    <form class="form-grid login-form" action="/accountExist" method="POST">
                        <div class="form-group">
                            <label for="email">Email address</label>
                            <div class="input-wrap">
                                <i class="fas fa-envelope"></i>
                                <input type="email" id="email" name="email" placeholder="name@example.com" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-wrap">
                                <i class="fas fa-lock"></i>
                                <input type="password" id="password" name="password" placeholder="Enter your password" required>
                                <button type="button" class="toggle-password" aria-label="Show password">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <label class="checkbox-row">
                            <input type="checkbox" name="remember">
                            <span>Keep me signed in on this device</span>
                        </label>

                        <button type="submit" class="btn btn-primary submit-btn">
                            <span>Sign in</span>
                            <i class="fas fa-arrow-right"></i>
                        </button>
                    </form>

                    <p class="auth-switch">New to SwapStyle? <a href="/Signin">Create your account here</a>.</p>
                </div>
            </div>
        </section>
    </main>

    <script>

        const passwordInput = document.getElementById('password');
        const toggleButton = document.querySelector('.toggle-password');

        if (toggleButton && passwordInput) {
            toggleButton.addEventListener('click', () => {
                const icon = toggleButton.querySelector('i');
                const isPassword = passwordInput.type === 'password';
                passwordInput.type = isPassword ? 'text' : 'password';
                icon.classList.toggle('fa-eye', !isPassword);
                icon.classList.toggle('fa-eye-slash', isPassword);
            });
        }

        const loginForm = document.querySelector('.login-form');
        const submitButton = document.querySelector('.submit-btn');

        if (loginForm && submitButton) {
            loginForm.addEventListener('submit', () => {
                submitButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Signing in</span>';
                submitButton.disabled = true;
            });
        }
    </script>
</body>
</html>
