<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Admin Panel | SwapStyle', stylesheet: '/adminpannel.css' }) %>
<body>
    <% const users = typeof Account !== 'undefined' && Array.isArray(Account) ? Account : []; %>
    <%- include('partials/navbar', { activePage: 'admin' }) %>


    <main class="page-shell">
        <section class="container section">
            <div class="hero-panel admin-hero">
                <div class="section-header">
                    <div>
                        <span class="eyebrow">Operations</span>
                        <h1>Admin panel</h1>
                        <p class="lead">A calmer admin view makes the data easier to scan and removes the script error caused by missing navigation elements in the previous version.</p>
                    </div>
                </div>
                <div class="stat-grid">
                    <div class="stats-card">
                        <span class="label">Registered users</span>
                        <span class="value"><%= users.length %></span>
                    </div>
                    <div class="stats-card">
                        <span class="label">Orders tracked</span>
                        <span class="value"><%= typeof totalOrders !== 'undefined' ? totalOrders : 0 %></span>
                    </div>
                    <div class="stats-card">
                        <span class="label">Listings tracked</span>
                        <span class="value"><%= typeof totalListings !== 'undefined' ? totalListings : 0 %></span>
                    </div>
                </div>
            </div>
        </section>

        <section class="container section">
            <div class="table-panel">
                <div class="section-header">
                    <div>
                        <span class="eyebrow">Users</span>
                        <h2>Manage accounts</h2>
                    </div>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (users.length > 0) { %>
                                <% users.forEach(user => { %>
                                    <tr>
                                        <td>
                                            <div class="avatar-row">
                                                <img src="https://randomuser.me/api/portraits/lego/1.jpg" alt="User avatar">
                                                <div>
                                                    <strong><%= [user.firstname, user.lastname].filter(Boolean).join(' ') || 'Unnamed user' %></strong>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= user.email || 'N/A' %></td>
                                        <td><%= user.phone || 'N/A' %></td>
                                        <td><span class="status-badge active">Active</span></td>
                                        <td>
                                            <% if (currentUser && String(currentUser.userId) !== String(user._id)) { %>
                                                <form action="/admin/delete-user" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this user? This action cannot be undone.');" style="display:inline;">
                                                    <input type="hidden" name="accountId" value="<%= user._id %>">
                                                    <button type="submit" class="btn btn-sm btn-danger" style="background-color: var(--danger, #dc3545); border-color: var(--danger, #dc3545); color: white; padding: 6px 12px; border-radius: 4px; font-size: 13px; cursor: pointer; transition: background-color 0.2s;">
                                                        <i class="fas fa-trash-alt" style="margin-right: 4px;"></i> Delete
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <span class="muted" style="font-size: 13px; color: #888;">(You)</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5">
                                        <div class="empty-state">No users found in the current database.</div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>


</body>
</html>
